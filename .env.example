# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.

# Sanity CMS (https://www.sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Sanity write token — needed for the contact form to save submissions.
# Generate at: manage.sanity.io -> your project -> API -> Tokens
# Permissions: Editor (or "Custom" with write access to the contactSubmission type)
SANITY_API_WRITE_TOKEN=

# Resend (https://resend.com) — for contact form email notifications
RESEND_API_KEY=

# The "from" address Resend sends on behalf of.
# For initial testing use: onboarding@resend.dev
# In production use a verified domain like: notifications@comfortandhope.org
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Where contact form submissions are sent
CONTACT_TO_EMAIL=
